{
  "decls": [
    {
      "kind": "monorepo",
      "name": "acme",
      "default_branch": "main",
      "package": "//"
    },
    {
      "kind": "github_import",
      "name": "widget",
      "repo": "acme/widget",
      "ref": "refs/heads/main",
      "into": null,
      "patches": [],
      "transforms": [
        {
          "transform": "replace",
          "before": "acme.internal/",
          "after": "",
          "paths": [
            "**/*.go"
          ],
          "regex": false
        },
        {
          "transform": "move",
          "src": "pkg",
          "dst": "lib"
        },
        {
          "transform": "copy",
          "src": "VERSION",
          "dst": "lib/VERSION"
        },
        {
          "transform": "rewrite_message",
          "before": "WIP: ",
          "after": "",
          "regex": false,
          "strip_trailers": [
            "Internal-Review"
          ],
          "add_trailers": [
            "Imported-by: capyfun"
          ]
        }
      ],
      "package": "//third_party/widget"
    }
  ]
}
