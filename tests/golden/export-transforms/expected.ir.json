        {
          "kind": "replace",
          "before": "(?m)^(\\s*)// (.*?) // @--OSS only--$",
          "after": "${1}${2}",
          "paths": [
            "**/*.go"
          ],
          "regex": true
        }
      ]
    }
  ],
