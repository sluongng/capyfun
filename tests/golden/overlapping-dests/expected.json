{
  "decls": [
    {
      "kind": "monorepo",
      "name": "acme",
      "default_branch": "main",
      "package": "//"
    },
    {
      "kind": "github_import",
      "name": "parent",
      "repo": "acme/parent",
      "ref": "refs/heads/main",
      "into": null,
      "patches": [],
      "package": "//third_party/parent"
    },
    {
      "kind": "github_import",
      "name": "backend",
      "repo": "acme/backend",
      "ref": "refs/heads/main",
      "into": null,
      "patches": [],
      "package": "//third_party/parent/backend"
    }
  ]
}
