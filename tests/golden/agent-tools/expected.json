{
  "decls": [
    {
      "kind": "monorepo",
      "name": "acme",
      "default_branch": "main",
      "package": "//"
    },
    {
      "kind": "agent",
      "name": "reviewer",
      "harness": "//tools/harness:claude_code",
      "model": "//tools/models:opus",
      "package": "//tools/agent"
    },
    {
      "kind": "agent",
      "name": "porter",
      "harness": "//tools/harness:codex",
      "model": "//tools/models:gpt",
      "package": "//tools/agent"
    },
    {
      "kind": "prompt_template",
      "name": "review",
      "src": "review.tmpl",
      "package": "//tools/agent/prompts"
    },
    {
      "kind": "harness",
      "name": "claude_code",
      "kind": "claude_code",
      "plugins": [
        "//tools/plugins:bazel"
      ],
      "skills": [],
      "package": "//tools/harness"
    },
    {
      "kind": "harness",
      "name": "codex",
      "kind": "codex",
      "plugins": [],
      "skills": [],
      "package": "//tools/harness"
    },
    {
      "kind": "model",
      "name": "opus",
      "provider": "anthropic",
      "id": "claude-opus-4-8",
      "credential": null,
      "package": "//tools/models"
    },
    {
      "kind": "model",
      "name": "gpt",
      "provider": "openai",
      "id": "gpt-5.5",
      "credential": "env:OPENAI_API_KEY",
      "package": "//tools/models"
    },
    {
      "kind": "git_repository",
      "name": "bazel",
      "repo": "acme/cc-plugin-bazel",
      "commit": "1111111111111111111111111111111111111111",
      "into": null,
      "package": "//tools/plugins"
    }
  ]
}
