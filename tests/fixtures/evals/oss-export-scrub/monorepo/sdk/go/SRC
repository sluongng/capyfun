# Export sdk/go/client/** out to github.com/acme/sdk-go as a PR, stripping the
# `client/` prefix and scrubbing visibility markers on the way out:
#   - @--internal only-- lines are deleted (never ship to OSS).
#   - @--OSS only-- lines are uncommented (commented internally, live in OSS).
github_export(
    name = "go-sdk",
    repo = "acme/sdk-go",
    branch = "main",
    from_path = "client",
    transforms = [
        replace(
            before = r"(?m)^.*@--internal only--.*\n",
            after = "",
            paths = ["**/*.go"],
            regex = True,
        ),
        replace(
            before = r"(?m)^(\s*)// (.*?) // @--OSS only--$",
            after = "${1}${2}",
            paths = ["**/*.go"],
            regex = True,
        ),
    ],
)
