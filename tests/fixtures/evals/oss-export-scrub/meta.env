KIND="export"
DESC="Publish sdk/go/client out to a standalone repo, scrubbing internal-only lines and enabling OSS-only lines on the way (deterministic replace transforms; no agent, 0 model calls)."
LABEL="//sdk/go:go-sdk"
REPO="acme/sdk-go"
DEST="client"
VERIFY="go build ./..."
AGENT_DESC="none (deterministic replace transform)"
EXPECT="pass"
SCRUB_FORBID="@--internal only--|control.internal.acme.corp"
