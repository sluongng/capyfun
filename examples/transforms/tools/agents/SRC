# Agent tool dependencies for the monorepo.
#
# Agents are composable: a `harness` (the runtime + its plugins/skills runfiles)
# and a `model` (the LLM) are paired into an `agent`. Multiple agents can coexist;
# models swap under a shared harness, and harnesses are reused across agents.
#
# Harness/model compatibility matters: a harness can only drive models it
# supports. `claude_code` runs Anthropic models; `codex` and `pi` run OpenAI and
# other open models. CapyFun validates these pairings.
#
# Package: //tools/agents

# --- harnesses (runtimes) ---

harness(
    name = "cc",
    kind = "claude_code",                  # Anthropic models only
    plugins = ["//tools/plugins:bazel"],   # runfiles (plugin targets, T4+)
    skills = ["//tools/skills:review"],     # runfiles (skill targets, T4+)
)

harness(
    name = "codex",
    kind = "codex",                        # OpenAI + open models
)

harness(
    name = "pi",
    kind = "pi",                           # OpenAI + open models
    skills = ["//tools/skills:review"],
)

# --- models ---

model(
    name = "opus48",
    provider = "anthropic",
    id = "claude-opus-4-8",
)

model(
    name = "gpt55",
    provider = "openai",
    id = "gpt-5.5",
)

model(
    name = "nemotron3ultra",
    provider = "nebius",
    id = "nvidia/nemotron-3-ultra",
)

# --- agents (harness + model) ---

# Claude Code drives the Anthropic Opus model.
agent(name = "reviewer", harness = ":cc", model = ":opus48")

# GPT-5.5 is an OpenAI model, so it runs under Codex (not Claude Code).
agent(name = "porter", harness = ":codex", model = ":gpt55")

# Nemotron-3 Ultra (served by Nebius) runs under Pi.
agent(name = "modernizer", harness = ":pi", model = ":nemotron3ultra")
