[40.976, "o", "\u001b[?25l\u001b[1d    name = \"widget\",\u001b[K\u001b[2;77H    repo = \"acme/widget\",\u001b[K\u001b[3;77H    transforms = [\u001b[K\u001b[4;77H        # structural - rewrites every mirrored commit:\u001b[K\u001b[5;77H        replace(before = \"acme.internal/\", after = \"\", paths = [\"**/*.go\"]),\u001b[K\u001b[6;77H        move(src = \"pkg\", dst = \"lib\"),\u001b[K\u001b[7;77H        # tip - applied once on top of the mirror:\u001b[K\u001b[8;77H        apply_patch(\"patches/0001-pin-toolchain.patch\"),\u001b[K\u001b[9;77H    ],\u001b[K\u001b[10;77H)\u001b[K\u001b[32m\u001b[1m\u001b[11;77Hcapyfun-demo\u001b[m\u000f$ # 2) upstream BEFORE \u2014 code in pkg/, imports acme.internal/log\u001b[K\u001b[32m\u001b[1m\u001b[12;77Hcapyfun-demo\u001b[m\u000f$ git -C '/tmp/capyfun-demo.gpSZdm/origins/acme/widget' show main:pkg/widget.go | sed -n '4,7p'\u001b[K\u001b[13;77H\u001b[K\nimport \"acme.internal/log\"\u001b[K\u001b[15;77H\u001b[K\n// New returns a greeting produced by the widget.\u001b[K\u001b[32m\u001b[1m\u001b[17;77Hcapyfun-demo\u001b[m\u000f$ # 3) import it \u2014 transforms run as the mirror is built\u001b[K\u001b[32m\u001b[1m\u001b[18;77Hcapyfun-demo\u001b[m\u000f$ capyfun import //third_party/widget:widget\u001b[K\u001b[19;77Himported 2 commit(s) for //third_party/widget:widget into third_party/widget; refs/heads/main now cef6c4e9762235d5bc7dcfb4a8\u001b[20;77H13858ef898c267\u001b[K\u001b[21;77Htip layer: 1 patch commit(s), 0 agent commit(s) (cache: 0 hit / 0 miss)\u001b[K\u001b[32m\u001b[1m\u001b[22;77Hcapyfun-demo\u001b[m\u000f$ # materialize the new tip into the working tree (watch the LEFT pane)\u001b[K\u001b[32m\u001b[1m\u001b[23;77Hcapyfun-demo\u001b[m\u000f$ git reset --hard main\u001b[K\u001b[24;77HHEAD is now at cef6c4e Apply patch third_party/widget/patches/0001-pin-toolchain.patch\u001b[K\u001b[32m\u001b[1m\u001b[25;77Hcapyfun-demo\u001b[m\u000f$ # 4) AFTER \u2014 moved pkg/ -> lib/, 'acme.internal/' scrubbed\u001b[K\u001b[32m\u001b[1m\u001b[26;77Hcapyfun-demo\u001b[m\u000f$ git show main:third_party/widget/lib/widget.go | sed -n '4,7p'\u001b[K\u001b[27;77H\u001b[K\nimport \"log\"\u001b[K\u001b[29;77H\u001b[K\n// New returns a greeting produced by the widget.\u001b[K\u001b[32m\u001b[1m\u001b[31;77Hcapyfun-demo\u001b[m\u000f$ # 5) go.mod pinned by the tip apply_patch\u001b[K\u001b[32m\u001b[1m\u001b[32;77Hcapyfun-demo\u001b[m\u000f$ git show main:third_party/widget/go.mod\u001b[K\u001b[33;77Hmodule acme/widget\u001b[K\u001b[34;77H\u001b[K\ngo 1.21\u001b[K\u001b[36;77H\u001b[K\ntoolchain go1.21.6\u001b[K\u001b[38;77H\u001b[K\nrequire acme.internal/log v1.5.0\u001b[K\u001b[32m\u001b[1m\u001b[40;77Hcapyfun-demo\u001b[m\u000f$ # 6) every commit maps back upstream via CapyFun-Origin\u001b[K\u001b[32m\u001b[1m\u001b[41;77Hcapyfun-demo\u001b[m\u000f$ git log main --format='%C(yellow)%h%C(reset) %s%n   %(trailers:key=CapyFun-Origin)' | sed '/^ *$/d' | head -8 \u001b[42;77Hcef6c4e Apply patch third_party/widget/patches/0001-pin-toolchain.patch\u001b[K\u001b[43;77Hf052b64 bump acme.internal/log to v1.5.0\u001b[K\u001b[44;77H   CapyFun-Origin: 684e1c0710039ed232ee18bea8b1c41b6b272de4\u001b[K\u001b[45;77H8aee166 initial widget\u001b[K\u001b[46;77H   CapyFun-Origin: 541428b7b5a05b9413be4a5b490467c37111d532\u001b[K\u001b[47;77Hee37d5e configure widget import\u001b[K\u001b[48;77H\u001b[K\u001b[34h\u001b[?25h"]
