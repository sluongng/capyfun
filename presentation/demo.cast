[3.74801, "o", "cat third_party/widget/SRC\u001b[3;77H"]
[3.748655, "o", "# Import acme/widget, transforming it on the way in.\u001b[4;77Hgithub_import(\u001b[5;77H    name = \"widget\",\u001b[6;77H    repo = \"acme/widget\",\u001b[7;77H    transforms = [\u001b[8;77H        # structural - rewrites every mirrored commit:\u001b[9;77H        replace(before = \"acme.internal/\", after = \"\", paths = [\"**/*.go\"]),\u001b[10;77H        move(src = \"pkg\", dst = \"lib\"),\u001b[11;77H        # tip - applied once on top of the mirror:\u001b[12;77H        apply_patch(\"patches/0001-pin-toolchain.patch\"),\u001b[13;77H        # generative - a coding agent modernizes the landed code:\u001b[14;77H        agent_transform(\u001b[15;77H            agent = \"//tools/agent:modernizer\",\u001b[16;77H            prompt = template(\"//tools/agent/prompts:modernize\"),\u001b[17;77H            paths = [\"lib/**\"],\u001b[18;77H        ),\u001b[19;77H    ],\u001b[20;77H)\u001b[21;77H"]
