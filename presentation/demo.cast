kage widget\u001b[K\u001b[25;77H\u001b[K\nimport \"log\"\u001b[K\u001b[32m\u001b[1m\u001b[27;77Hcapyfun-demo\u001b[m\u000f$ # 5) go.mod pinned by the tip apply_patch\u001b[K\u001b[32m\u001b[1m\u001b[28;77Hcapyfun-demo\u001b[m\u000f$ git show main:third_party/widget/go.mod\u001b[K\u001b[29;77Hmodule acme/widget\u001b[K\u001b[30;77H\u001b[K\ngo 1.21\u001b[K\u001b[32;77H\u001b[K\ntoolchain go1.21.6\u001b[K\u001b[34;77H\u001b[K\nrequire acme.internal/log v1.5.0\u001b[K\u001b[32m\u001b[1m\u001b[36;77Hcapyfun-demo\u001b[m\u000f$ # 6) provenance: CapyFun-Origin (mirror) + CapyFun-Agent (generative)\u001b[K\u001b[32m\u001b[1m\u001b[37;77Hcapyfun-demo\u001b[m\u000f$ git log main --format='%C(yellow)%h%C(reset) %s%n   %(trailers:key=CapyFun-Origin,key=CapyFun-Agent,separator=\u001b[38;77H%x20)' | sed '/^ *$/d' | head -10\u001b[K\u001b[39;77Hdfa6c14 Apply agent_transform //tools/agent:modernizer\u001b[K\u001b[40;77H   CapyFun-Agent: //tools/agent:modernizer\u001b[K\u001b[41;77H1480c4e Apply patch third_party/widget/patches/0001-pin-toolchain.patch\u001b[K\u001b[42;77He858174 bump acme.internal/log to v1.5.0\u001b[K\u001b[43;77H   CapyFun-Origin: 62bb87d95f633cf62c243e9d5bd754228bb8c976\u001b[K\u001b[44;77Hacd1538 initial widget\u001b[K\u001b[45;77H   CapyFun-Origin: 74b970e5e49a34e057fe6a77b417d1f2145c62f0\u001b[K\u001b[46;77H916aa28 configure widget import\u001b[K\u001b[32m\u001b[1m\u001b[47;77Hcapyfun-demo\u001b[m\u000f$ # imperative + generative \u2014 reproducible, every file traceable.\u001b[K\u001b[48;77H\u001b[K\u001b[1;76H\u2502\u001b[2;76H\u2502\u001b[3;76H\u2502\u001b[4;76H\u2502\u001b[5;76H\u2502\u001b[6;76H\u2502\u001b[7;76H\u2502\u001b[8;76H\u2502\u001b[9;76H\u2502\u001b[10;76H\u2502\u001b[11;76H\u2502\u001b[12;76H\u2502\u001b[13;76H\u2502\u001b[14;76H\u2502\u001b[15;76H\u2502\u001b[16;76H\u2502\u001b[17;76H\u2502\u001b[18;76H\u2502\u001b[19;76H\u2502\u001b[20;76H\u2502\u001b[21;76H\u2502\u001b[22;76H\u2502\u001b[23;76H\u2502\u001b[24;76H\u2502\u001b[25;76H\u2502\u001b[26;76H\u001b[32m\u2502\u001b[27;76H\u2502\u001b[28;76H\u2502\u001b[29;76H\u2502\u001b[30;76H\u2502\u001b[31;76H\u2502\u001b[32;76H\u2502\u001b[33;76H\u2502\u001b[34;76H\u2502\u001b[35;76H\u2502\u001b[36;76H\u2502\u001b[37;76H\u2502\u001b[38;76H\u2502\u001b[39;76H\u2502\u001b[40;76H\u2502\u001b[41;76H\u2502\u001b[42;76H\u2502\u001b[43;76H\u2502\u001b[44;76H\u2502\u001b[45;76H\u2502\u001b[46;76H\u2502\u001b[47;76H\u2502\u001b[48;76H\u2502\u001b[m\u000f\u001b[34h\u001b[?25h\u001b[32m\u001b[1mcapyfun-demo\u001b[m\u000f$ "]
